<?xml version="1.0" encoding="UTF-8"?>
<!--
    SpotBugs exclude filter for the BBoxDB project.

    Two kinds of things are excluded here:

      1. Generated / third-party code that is not maintained by hand.
      2. Whole bug patterns that are intentionally accepted for this project
         (defensive-copy noise, intentional process exits, domain-specific
         floating point comparisons, etc.). These would otherwise produce
         hundreds of low-value findings on an existing code base.

    Genuine correctness bugs are NOT excluded here; they are fixed in the
    source instead.
-->
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

    <!-- ============================================================= -->
    <!-- Generated protocol buffer code (GTFS realtime bindings)       -->
    <!-- ============================================================= -->
    <Match>
        <Class name="~com\.google\.transit\.realtime\..*" />
    </Match>

    <!-- ============================================================= -->
    <!-- Exposure of internal representation (mutable references).      -->
    <!-- Defensive copying is deliberately avoided on the hot paths of  -->
    <!-- the storage engine, so these patterns are accepted globally.   -->
    <!-- ============================================================= -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2,EI_EXPOSE_STATIC_REP2,MS_EXPOSE_REP,MS_MUTABLE_ARRAY,MS_MUTABLE_COLLECTION,MS_MUTABLE_COLLECTION_PKGPROTECT,MS_SHOULD_BE_FINAL,PA_PUBLIC_PRIMITIVE_ATTRIBUTE" />
    </Match>

</FindBugsFilter>
